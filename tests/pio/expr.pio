; Expression operators and precedence — the differential makes real pioasm the
; authority. `.define` values take full expressions; instruction operands take a
; parenthesised expression (pioasm requires the parens). Mixes glued and spaced
; forms, defines referencing earlier defines, label arithmetic, and bin/hex.
.define A 0b1010
.define B (A + 6)
.define C A*2 - 3
.define D 1 + 2 & 3
; `::` binds loosest of all in pioasm's grammar (and is right-recursive), so it
; applies to the whole expression to its right:
;   E = ::(2 >> 27) = ::0 = 0        — not (::2) >> 27 = 8
;   F = ::(A & 3) >> 28 = ::2 >> 28  — the outer parens stop the reverse, = 4
.define E (::2 >> 27) & 0x1F
.define F (::A & 3) >> 28
.program exprcov
start:
    set x, (A & 0x0F)
    set y, (A | 1)
    set x, (B & 0x1F)
    set y, (C & 0x1F)
    set x, D
    set y, E
    set x, F
    out pins, (8 >> 1)
    in pins, (1 << 2)
    jmp x!=y, (start + 1)
    jmp start
