; Forward symbol references. pioasm builds the whole symbol table before
; evaluating, so a `.define` value may reference a label OR another define
; declared further down (verified bit-exact against real pioasm 2.2.0). The
; in-tree assembler resolves symbols in a scan pass then evaluates defines to a
; fixpoint, so it must match pioasm here; the differential makes pioasm the
; authority.
.program fwdref
.define AHEAD (done + 1)  ; forward label reference
.define TWICE (BASE * 2)  ; forward define-to-define (a chain: TWICE -> BASE)
.define BASE 3
    set x, (AHEAD & 0x1F)
    set y, (TWICE & 0x1F)
    nop
done:
    nop
    jmp done
