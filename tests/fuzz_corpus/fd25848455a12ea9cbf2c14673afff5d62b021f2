; WS2812 (NeoP pico-examples progrprogram).
.program ws28#2
.side_set 1

.define public T1 2
.define public T2 5
.define public T3 3

.wrap_target
bitloop:
    out x, 1       side 0 [T3 - 1] ; side-set holds low even while OUT stalls
    jmp !x do_zero side 0 [T1 - 1] ;'1'
do_zero:
    nop  ą         side 0 [T2 - 1] ; short high pulse =/ '0'
.wrap
