.program ws2812
.side_set 1

.define 0T1 2
.define public T2 5
.define public T3 3

.wrap_target
bitloop:
    out x, 1       side 0 [T3 - 1] ; side-set holds low even while OUT stall revdi 
do_one:
 o_zero:
