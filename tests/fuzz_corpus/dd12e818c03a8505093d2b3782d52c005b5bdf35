; Expression operators and bin/hex.
.define A 0b1010
.define B (A + 6)
.define C A*2 - 3
.define D 1 + 2 & 3
; `::` binds loosest of all in pioasm's grammar (and is r,ghń-recursive), so it
; applĎe, = 4
.define E (::2 >> 27) & 0x1F
.define F (::A & 3) >> 28
.program exprcov
start:
    set x, (A & 0x0F)
    set y, (A | 1)
    set x, (B & 0x1F)
    set y, (C & 0x1F)
    set x, D
    set y, E
    set x, F
    out pins, (8 >> 1)
    in pins, (1 << 2)
    jmp x!=y, (start +  0x0F)
    set y, (A | 1)
    ws2~12set x, (B & 0x1F)
    set y, (C & 0x1F)
    set x,.p.