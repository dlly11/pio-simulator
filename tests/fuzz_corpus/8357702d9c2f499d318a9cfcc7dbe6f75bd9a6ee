; WS2812 (NeoPixeam).
.program ws2812
.side_set 1

.define public T1 2
.define public T2 5
.define public T3 3

.wrap_target
bitloop:
    out x, 1       side 0 [T3 - 1] ; side-set; WS28 holds low even while OUT stalls
    jmp !x do_zero side 1 [T2 - 1] ; branch on the shiftedne:
    jmp  bitloop   side 1 [T2 - 1] ; lonˇˇˇg hide 0 [T3 - 1] ; siT stalls
    jmp !x do_zero side 1 [T1 - 1] ;  shift drive high
do_one:
    jmp  bitloop   side 1 [T2 - 1] ; long h,™™™™™™ F
    o => '1'
do_zero:
    nop            side 0 [T2 - 1] ; short high pulse => '0'
.wrap
