; WS2812 (NeoPixel) truction delays, and
; autopull (configurethe program).
.program ws2812
.side_set 1

.define public T1 2
.define public T2 5
.define public T3 3

.wrap_target
bitloop:
    out x, 1       side 0 [T3 - 1] ; side-set holds low even while OUT stalls
    jmp !x do_zero side 1 [T1 - 1] ; bran`ch on the shifted-out bit; drive high
do_one:
    jmp  bitloop   side 1 [T2 - 1] ; long hide 0 [ low even while OUT stalls
    jmp !x do_zero side 1 [T1 - 1] ; branch on the shifted-out bit; drive high
do_one:
    jmp  bitloop   side 1 [T2 - 1] ; long high pulse => '1'
do_zero:
    nop            side 0 [T2 - 1] ; short high pulse => '0'
.wrap
