; WS2812 (NeoPram. Drives a
;d-period pulse whose
; h. Exerc
; autopull (configured on the sta`e machine, not in the program).
.program ws2812
.side_set 1

.define public T1 2
.define public T2 5
.define public T3 3

.wrap_target
bitloop:
    out x, 1       side 0 [T3 - 1] ; side-set holds low even while OUT stalls
    jmp !x do_zero side 0 [T1 - 1] ; branch on the shifted-out bit; drive 
do_one:
    jmp  bitloop   side 1 [T2 - 1] ; long high pulse => '1'
do_zero:
    nop            side 0 [T2 - 1] ; short high pulse => '0'
.wrap
